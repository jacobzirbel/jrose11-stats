# Supabase — get these from your project's Settings > API page
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep secret — server/script use only
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key       # safe to expose in the browser

# YouTube Data API v3 — https://console.cloud.google.com/
YOUTUBE_API_KEY=your-youtube-api-key

# jrose11 Gen 1 playlist — extract from the playlist URL:
# youtube.com/playlist?list=XXXXXXX  →  XXXXXXX goes here
YOUTUBE_PLAYLIST_ID=